{
  "name": "plan1",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:related": "vitest run --related",
    "test:changed": "vitest run --changed origin/main",
    "test:staged": "git diff --cached --name-only --diff-filter=ACMR | xargs --no-run-if-empty vitest run --related",
    "test:e2e:qa-gate": "playwright test --config=playwright.config.ts",
    "test:e2e:qa-gate:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts --grep @smoke",
    "test:e2e:mutation": "playwright test --config=playwright.config.ts --grep @mutation",
    "test:e2e:changed": "playwright test --config=playwright.config.ts --only-changed",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --since main",
    "prepare": "husky",
    "i18n:translate": "i18n-ai-translate translate -i messages/en.json -o es pt fr de ja ru ar hi -e claude -m claude-sonnet-4-5 -p '{' -s '}' --skip-translation-verification --skip-styling-verification --verbose",
    "i18n:translate:zh": "i18n-ai-translate translate -i messages/en.json -o zh -e claude -m claude-sonnet-4-5 -p '{' -s '}' --skip-translation-verification --skip-styling-verification --verbose && mv messages/zh.json messages/zh-CN.json",
    "i18n:translate:all": "npm run i18n:translate && npm run i18n:translate:zh",
    "i18n:diff": "i18n-ai-translate diff -l en -e claude -m claude-sonnet-4-5 -p '{' -s '}' --skip-translation-verification --skip-styling-verification --verbose"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/nextjs": "^10.51.0",
    "@vercel/functions": "^3.4.4",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@fast-check/vitest": "^0.4.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.4",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "i18n-ai-translate": "^4.1.2",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
